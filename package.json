{
  "name": "nimage",
  "version": "0.1.0",
  "description": "Native image decoding via NAPI - libraw for RAW, libheif for HEIC, with ICC color profile support",
  "main": "lib/index.js",
  "files": [
    "lib/",
    "dist/"
  ],
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "setup:deps": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1 -SkipBuild",
    "build": "node-gyp rebuild",
    "build:debug": "node-gyp rebuild --debug",
    "build:clean": "node-gyp clean",
    "rebuild": "node-gyp rebuild",
    "rebuild:electron": "npx @electron/rebuild -f -w nimage",
    "test": "node test/index.test.js",
    "package": "node scripts/package-binary.js",
    "prepublishOnly": "npm run build && npm run package"
  },
  "keywords": [
    "image",
    "raw",
    "heic",
    "heif",
    "cr2",
    "nef",
    "arw",
    "libraw",
    "libheif",
    "napi",
    "native",
    "decoder",
    "icc",
    "color-profile"
  ],
  "author": "David Renelt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/herrbasan/nImage.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "win32",
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "dependencies": {
    "jpeg-js": "^0.4.4",
    "node-addon-api": "^8.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "node-gyp": "^12.2.0"
  }
}
